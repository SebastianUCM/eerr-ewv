# --- Frontend (Vite): URL base del API del chat, sin barra final. En producción: https://tu-servicio.up.railway.app
VITE_CHAT_API_URL=http://127.0.0.1:8000

# --- Backend (api_ia.py): clave de Google AI Studio / Gemini (nunca subas el valor real a git)
GEMINI_API_KEY=

# Orígenes CORS permitidos, separados por coma. En producción: https://tu-app.pages.dev
# Usa * solo en desarrollo.
CORS_ORIGINS=*
